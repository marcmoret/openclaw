# Sensitive / personal memory
memory/
MEMORY.md

# OpenClaw transient media and runtime noise
media/
*.log
*.tmp

# Python cache
__pycache__/
*.pyc

# Node / package noise
node_modules/

# OS/editor noise
.DS_Store
Thumbs.db

# Knowledge-base generated indexes / heavier transient outputs if desired
llm-knowledge-bases/raw/_index/

# Optional: generated visuals if large/noisy
llm-knowledge-bases/outputs/visuals/*.png
llm-knowledge-bases/outputs/visuals/*.jpg
llm-knowledge-bases/outputs/visuals/*.svg

# Optional local-only app state
*.sqlite
*.db

# Local OpenClaw runtime / nested repos
.openclaw/
openclaw/
# Angular specific
/dist/
/out-tsc/
/tmp/
/coverage/
/e2e/test-output/
/.angular/
.angular/

# Node modules and dependency files
/node_modules/
/package-lock.json
/yarn.lock

# Environment files
/.env

# Angular CLI and build artefacts
/.angular-cli.json
/.ng/

# TypeScript cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
